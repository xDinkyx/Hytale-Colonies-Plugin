{
  "$Comment": "Shared base for harvester-type colonist roles (Miner, Woodsman, and future harvesters). All states except WaitingForWork are defined here; job-specific tool checks and scanning go in WaitingForWorkComponent.",
  "Type": "Abstract",
  "StartState": "Idle",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "server.npcRoles.Colonist.name",
      "Description": "Translation key for the NPC display name."
    },
    "Appearance": {
      "Value": "Mannequin",
      "Description": "Model to use for this colonist."
    },
    "MaxHealth": {
      "Value": 20,
      "Description": "Maximum health points."
    },
    "MaxSpeed": {
      "Value": 3,
      "Description": "Maximum walk speed."
    },
    "GatherType": {
      "Value": "Rocks",
      "Description": "Gather type passed to EquipBestTool on entering the Working main state."
    },
    "DebugCategory": {
      "Value": "COLONIST_JOB",
      "Description": "Debug log category name used in all LogDebug actions for this role."
    },
    "WaitingForWorkComponent": {
      "Value": "Component_Instruction_Colonist_WaitingForWork_Miner",
      "Description": "Component_Instruction that provides the WaitingForWork block (tool checks + target scanning). Required: override in each variant."
    }
  },
  "Appearance": { "Compute": "Appearance" },
  "MaxHealth": { "Compute": "MaxHealth" },
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "InventorySize": 12,
  "MotionControllerList": [
    { "Type": "Walk", "MaxWalkSpeed": { "Compute": "MaxSpeed" } }
  ],
  "StateTransitions": [
    {
      "$Comment": "Equip best tool when entering Working main state.",
      "States": [{ "From": [], "To": ["Working"] }],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition -> Working.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
        { "Type": "EquipBestTool", "GatherType": { "Compute": "GatherType" } }
      ]
    },
    {
      "$Comment": "Put tool away when leaving Working main state.",
      "States": [{ "From": ["Working"], "To": [] }],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition Working ->.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
        { "Type": "Inventory", "Operation": "ClearHeldItem", "UseTarget": false }
      ]
    },
    {
      "$Comment": "Reset any stuck blocking instruction chain when entering Idle main state.",
      "States": [{ "From": [], "To": ["Idle"] }],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition -> Idle.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
        { "Type": "ResetInstructions" }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Working -- gates all working-shift behavior. Fires for any Working substate.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Working", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "Harvesting -- approach block and break it.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0, "MinRange": 1.5 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 1.0, "SlowDownDistance": 2.0, "RelativeSpeed": 0.8 }
            },
            {
              "Sensor": { "Type": "JobTarget", "Range": 2.5 },
              "ActionsBlocking": true,
              "Actions": [
                { "Type": "LogDebug", "Message": "Harvesting: breaking block.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "EquipBestTool" },
                { "Type": "HarvestBlock", "DamageScale": 0.1 },
                { "Type": "Timeout", "Delay": [0.5, 0.5] }
              ]
            }
          ]
        },
        {
          "$Comment": "Harvesting -- when job-target block is air, notify ECS working system.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Harvesting: block broken -- notifying ECS.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "NotifyBlockBroken" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToWorkSite -- seek to claimed block. On arrival transition to Working.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkSite", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "JobTarget", "Range": 2.5 },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToWorkSite: arrived -> Working.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "Working" }
              ]
            }
          ]
        },
        {
          "$Comment": "WaitingForWork -- job-specific tool checks and work scanning (delegated to variant component).",
          "Sensor": { "Type": "State", "State": ".WaitingForWork", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "WaitingForWorkComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.WaitingForWork" ]
            }
          ]
        },
        {
          "$Comment": "CollectingDrops -- wander and pick up drops. Timer elapsed -> DeliveringItems.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".CollectingDrops", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "BodyMotion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 60, "RelativeSpeed": 0.5 }
            },
            {
              "Continue": true,
              "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: picking up item.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "PickUpItem", "Hoover": true }
              ]
            },
            {
              "$Comment": "Timer elapsed -- transition to DeliveringItems.",
              "Sensor": { "Type": "CollectionTimerElapsed" },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: timer elapsed -> DeliveringItems.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "DeliveringItems" }
              ]
            }
          ]
        },
        {
          "$Comment": "DeliveringItems -- find chest near workstation and deposit inventory.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".DeliveringItems", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: scanning for delivery container.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "FindDeliveryContainer" }
              ]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "$Comment": "Arrived at container -- deposit items then head home.",
              "Sensor": { "Type": "JobTarget", "Range": 3.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: depositing and heading home.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "DepositItems" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToHome" }
              ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    },
    {
      "$Comment": "Idle -- gates all off-shift behavior. Fires for any Idle substate.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Idle", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "TravelingToWorkstation -- seek to workstation. On arrival begin WaitingForWork.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkstation", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [{ "Type": "NavigateToWorkstation" }]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToWorkstation: arrived -> WaitingForWork.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "WaitingForWork" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToHome -- return to workstation area after delivery.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToHome", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [{ "Type": "NavigateToWorkstation" }]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToHome: arrived -> Idle.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "Idle" }
              ]
            }
          ]
        },
        {
          "$Comment": "Default -- transient pass-through. Navigate to workstation and begin travel.",
          "Sensor": { "Type": "State", "State": ".Default", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Default: navigating to workstation.", "Category": { "Compute": "DebugCategory" }, "Level": "INFO" },
                { "Type": "NavigateToWorkstation" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToWorkstation" }
              ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    },
    { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
  ]
}

{
  "Type": "Generic",
  "Appearance": "Mannequin",
  "NameTranslationKey": "server.npcRoles.Colonist_Miner.name",
  "MaxHealth": 20,
  "InventorySize": 12,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 3
    }
  ],
  "Instructions": [
    {
      "$Comment": "TravelingToJob -- seek to claimed mine block. ECS writes NavTarget via PathFindingSystem.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "TravelingToJob" },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "Working -- approach block and mine. Seek handles final approach so the NPC gets close enough; mine fires once within range.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "Working" },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0, "MinRange": 1.5 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 1.0, "SlowDownDistance": 2.0, "RelativeSpeed": 0.8 }
        },
        {
          "Sensor": { "Type": "JobTarget", "Range": 2.5 },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "EquipBestTool" },
            { "Type": "HarvestBlock", "DamageScale": 0.1 },
            { "Type": "Timeout", "Delay": [0.5, 0.5] }
          ]
        }
      ]
    },
    {
      "$Comment": "Working -- when job-target block is air, notify ECS. ECS decides the next state (quota check, next block, or collect).",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "Working" },
      "Instructions": [
        {
          "Sensor": { "Type": "JobTargetBroken" },
          "Actions": [
            { "Type": "NotifyBlockBroken" }
          ]
        }
      ]
    },
    {
      "$Comment": "CollectingDrops -- wander area and pick up drops while ECS delivery pipeline runs.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "CollectingDrops" },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": { "Type": "Any" },
          "BodyMotion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 60, "RelativeSpeed": 0.5 }
        },
        {
          "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
          "Actions": [
            { "Type": "PickUpItem", "Hoover": true }
          ]
        }
      ]
    },
    {
      "$Comment": "DeliveringItems -- seek to delivery container. ECS writes NavTarget.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "DeliveringItems" },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "TravelingHome -- seek back to workstation. ECS writes NavTarget.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "TravelingHome" },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "Idling -- wander near workstation; confused particle when tools are missing.",
      "Continue": true,
      "Sensor": { "Type": "EcsJobState", "JobState": "Idling" },
      "Instructions": [
        {
          "$Comment": "Wander near workstation (WanderInCircle uses leash point set by ECS). Continue: true so tool-check blocks below also run.",
          "Continue": true,
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0 },
          "BodyMotion": {
            "Type": "Sequence",
            "Looped": true,
            "Motions": [
              { "Type": "Timer", "Time": [ 4, 6 ], "Motion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 0.4 } },
              { "Type": "Timer", "Time": [ 1, 2 ], "Motion": { "Type": "Nothing" } }
            ]
          }
        },
        {
          "$Comment": "No pickaxe -- confused particle + wait.",
          "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["Tool_Pickaxe_*"], "CountRange": [1, 999] }] } },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [ 0, 2.1, 0 ] },
            { "Type": "Timeout", "Delay": [ 3, 3 ] }
          ]
        },
        {
          "$Comment": "No shovel -- confused particle + wait.",
          "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["Tool_Shovel_*"], "CountRange": [1, 999] }] } },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [ 0, 2.1, 0 ] },
            { "Type": "Timeout", "Delay": [ 3, 3 ] }
          ]
        }
      ]
    },
    {
      "Sensor": { "Type": "Any" },
      "BodyMotion": { "Type": "Nothing" }
    }
  ]
}

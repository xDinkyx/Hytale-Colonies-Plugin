{
  "Type": "Generic",
  "StartState": "Idle",
  "Appearance": "Mannequin",
  "NameTranslationKey": "server.npcRoles.Colonist_Miner.name",
  "MaxHealth": 20,
  "InventorySize": 12,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 3
    }
  ],
  "StateTransitions": [
    {
      "$Comment": "Equip best mining tool when entering Working main state.",
      "States": [
        { "From": [], "To": ["Working"] }
      ],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition -> Working.", "Category": "MINER_JOB", "Level": "INFO" },
        { "Type": "EquipBestTool", "GatherType": "Rocks" }
      ]
    },
    {
      "$Comment": "Put tool away when leaving Working main state.",
      "States": [
        { "From": ["Working"], "To": [] }
      ],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition Working ->.", "Category": "MINER_JOB", "Level": "INFO" },
        { "Type": "Inventory", "Operation": "ClearHeldItem", "UseTarget": false }
      ]
    },
    {
      "$Comment": "Reset any stuck blocking instruction chain when entering Idle main state.",
      "States": [
        { "From": [], "To": ["Idle"] }
      ],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition -> Idle.", "Category": "MINER_JOB", "Level": "INFO" },
        { "Type": "ResetInstructions" }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Working -- gates all working-shift behavior. Fires for any Working substate.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Working", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "Harvesting -- approach block and mine.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0, "MinRange": 1.5 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 1.0, "SlowDownDistance": 2.0, "RelativeSpeed": 0.8 }
            },
            {
              "Sensor": { "Type": "JobTarget", "Range": 2.5 },
              "ActionsBlocking": true,
              "Actions": [
                { "Type": "LogDebug", "Message": "Harvesting: mining block.", "Category": "MINER_JOB", "Level": "FINE" },
                { "Type": "EquipBestTool" },
                { "Type": "HarvestBlock", "DamageScale": 0.1 },
                { "Type": "Timeout", "Delay": [0.5, 0.5] }
              ]
            }
          ]
        },
        {
          "$Comment": "Harvesting -- when job-target block is air, notify ECS working system.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Harvesting: block broken -- notifying ECS.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "NotifyBlockBroken" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToWorkSite -- seek to claimed mine block. On arrival transition to Harvesting.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkSite", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "JobTarget", "Range": 2.5 },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToWorkSite: arrived -> Working.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "Working" }
              ]
            }
          ]
        },
        {
          "$Comment": "WaitingForWork -- wander at workstation, scan for mine block. Tool checks block early.",
          "Sensor": { "Type": "State", "State": ".WaitingForWork", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "BodyMotion": {
                "Type": "Sequence",
                "Looped": true,
                "Motions": [
                  { "Type": "Timer", "Time": [4, 6], "Motion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 0.4 } },
                  { "Type": "Timer", "Time": [1, 2], "Motion": { "Type": "Nothing" } }
                ]
              }
            },
            {
              "$Comment": "No pickaxe -- confused particle + wait.",
              "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["Tool_Pickaxe_*"], "CountRange": [1, 999] }] } },
              "ActionsBlocking": true,
              "Actions": [
                { "Type": "LogDebug", "Message": "WaitingForWork: missing pickaxe -- showing confused particle.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
                { "Type": "Timeout", "Delay": [3, 3] }
              ]
            },
            {
              "$Comment": "No shovel -- confused particle + wait.",
              "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["Tool_Shovel_*"], "CountRange": [1, 999] }] } },
              "ActionsBlocking": true,
              "Actions": [
                { "Type": "LogDebug", "Message": "WaitingForWork: missing shovel -- showing confused particle.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
                { "Type": "Timeout", "Delay": [3, 3] }
              ]
            },
            {
              "$Comment": "Has both tools -- scan for the next mine block and claim it.",
              "Continue": true,
              "Sensor": {
                "Type": "Self",
                "Filters": [
                  {
                    "Type": "And",
                    "Filters": [
                      { "Type": "Inventory", "Items": [ "*_Shovel*", "*_Pickaxe*" ] }
                    ]
                  }
                ]
              },
              "Actions": [
                { "Type": "LogDebug", "Message": "WaitingForWork: scanning for next mine block.", "Category": "MINER_JOB", "Level": "FINE" },
                { "Type": "SeekNextMineBlock" }
              ]
            },
            {
              "$Comment": "Target found -- travel to the claimed mine block.",
              "Sensor": { "Type": "JobTargetExists" },
              "Actions": [
                { "Type": "LogDebug", "Message": "WaitingForWork: target found -> TravelingToWorkSite.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToWorkSite" }
              ]
            }
          ]
        },
        {
          "$Comment": "CollectingDrops -- wander and pick up ore/stone drops. After 5 s, deliver.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".CollectingDrops", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "BodyMotion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 60, "RelativeSpeed": 0.5 }
            },
            {
              "Continue": true,
              "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: picking up item.", "Category": "MINER_JOB", "Level": "FINE" },
                { "Type": "PickUpItem", "Hoover": true }
              ]
            },
            {
              "$Comment": "Timer elapsed -- transition to DeliveringItems.",
              "Sensor": { "Type": "CollectionTimerElapsed" },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: timer elapsed -> DeliveringItems.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "DeliveringItems" }
              ]
            }
          ]
        },
        {
          "$Comment": "DeliveringItems -- find chest near workstation and deposit inventory.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".DeliveringItems", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: scanning for delivery container.", "Category": "MINER_JOB", "Level": "FINE" },
                { "Type": "FindDeliveryContainer" }
              ]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "$Comment": "Arrived at container -- deposit items then head home.",
              "Sensor": { "Type": "JobTarget", "Range": 3.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: depositing and heading home.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "DepositItems" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToHome" }
              ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    },
    {
      "$Comment": "Idle -- gates all off-shift behavior. Fires for any Idle substate.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Idle", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "TravelingToWorkstation -- seek to workstation. On arrival begin WaitingForWork.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkstation", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "NavigateToWorkstation" }
              ]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToWorkstation: arrived -> WaitingForWork.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "WaitingForWork" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToHome -- return to workstation area after delivery.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToHome", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "NavigateToWorkstation" }
              ]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToHome: arrived -> Idle.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "SetEcsJobState", "JobState": "Idle" }
              ]
            }
          ]
        },
        {
          "$Comment": "Default -- transient pass-through. Set nav and immediately transition to TravelingToWorkstation.",
          "Sensor": { "Type": "State", "State": ".Default", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Default: navigating to workstation.", "Category": "MINER_JOB", "Level": "INFO" },
                { "Type": "NavigateToWorkstation" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToWorkstation" }
              ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    }
  ]
}
{
  "$Comment": "Miner colonist role — handles shafting out a mine block-by-block up to a per-run quota.",
  "Type": "Generic",
  "Appearance": "Mannequin",
  "MaxHealth": 20,
  "StartState": "Idle",
  "NameTranslationKey": "server.npcRoles.Colonist_Miner.name",
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 4
    }
  ],
  "InventorySize": 12,
  "StateTransitions": [
    {
      "$Comment": "When transitioning from Collecting back to Idle, reset the per-run counter.",
      "States": [
        {
          "From": ["Collecting"],
          "To": ["Idle"]
        }
      ],
      "Actions": [
        { "Type": "ResetBlocksMined" }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Global navigation — always running. Drives body toward the NavTarget slot when a position is set.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": {
            "Type": "ReadPosition",
            "Slot": "NavTarget",
            "Range": 200.0,
            "MinRange": 1.5
          },
          "BodyMotion": {
            "Type": "Seek",
            "StopDistance": 1.5,
            "SlowDownDistance": 3,
            "RelativeSpeed": 1.0
          }
        }
      ]
    },
    {
      "$Comment": "Global harvesting — fires in any state when within range of the job target. ActionsBlocking advances equip→swing→delay in sequence, limiting hits to one per Timeout interval.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": {
            "Type": "JobTarget",
            "Range": 5.0
          },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "EquipBestTool" },
            { "Type": "HarvestBlock", "DamageScale": 0.1 },
            { "Type": "Timeout", "Delay": [0.5, 0.5] }
          ]
        }
      ]
    },
    {
      "$Comment": "Global break detection — when Working and the job target block is now air, increment the blocks-mined counter and release the claim. Runs every tick via Continue:true so the break is caught in the same tick it happens.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Working" },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "IncrementBlocksMined" },
                { "Type": "ReleaseJobTarget" }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Global seek-next — when Working, quota not yet reached, and no current target after a release, claim the next mine block.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Working" },
          "Instructions": [
            {
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  { "Type": "Not", "Sensor": { "Type": "MineQuotaReached" } },
                  { "Type": "Not", "Sensor": { "Type": "JobTargetExists" } }
                ]
              },
              "Actions": [
                { "Type": "SeekNextMineBlock" }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Global quota check — when Working and the quota has been reached, start the ECS delivery pipeline and transition to Collecting.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Working" },
          "Instructions": [
            {
              "Sensor": { "Type": "MineQuotaReached" },
              "Actions": [
                { "Type": "SetEcsJobState", "State": "CollectingDrops" },
                { "Type": "State", "State": "Collecting" }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Global no-work fallback — when Working and no blocks remain in the shaft (shaft exhausted), start the ECS delivery pipeline and transition to Collecting.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Working" },
          "Instructions": [
            {
              "Sensor": { "Type": "NoWorkAvailable" },
              "Actions": [
                { "Type": "SetEcsJobState", "State": "CollectingDrops" },
                { "Type": "State", "State": "Collecting" }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "=== IDLE STATE ===",
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Idle" },
          "Instructions": [
            {
              "$Comment": "Only work when the ECS delivery pipeline is idle.",
              "Sensor": { "Type": "EcsJobState", "State": "Idle" },
              "Instructions": [
                {
                  "$Comment": "No pickaxe — show confused particle and wait. ActionsBlocking ensures the particle fires once, then waits, rather than every tick.",
                  "Sensor": {
                    "Type": "Not",
                    "Sensor": { "Type": "HasTool", "GatherType": "Rocks" }
                  },
                  "ActionsBlocking": true,
                  "Actions": [
                    { "Type": "SpawnParticles", "ParticleSystem": "Question", "Offset": [0, 2.1, 0] },
                    { "Type": "Timeout", "Delay": [3, 3] }
                  ]
                },
                {
                  "$Comment": "No shovel — show confused particle and wait. ActionsBlocking ensures the particle fires once, then waits, rather than every tick.",
                  "Sensor": {
                    "Type": "Not",
                    "Sensor": { "Type": "HasTool", "GatherType": "Soils" }
                  },
                  "ActionsBlocking": true,
                  "Actions": [
                    { "Type": "SpawnParticles", "ParticleSystem": "Question", "Offset": [0, 2.1, 0] },
                    { "Type": "Timeout", "Delay": [3, 3] }
                  ]
                },
                {
                  "$Comment": "Persisted job target points to a broken block (e.g. after restart) — release it immediately so we don't navigate to an empty position.",
                  "Sensor": { "Type": "JobTargetBroken" },
                  "Actions": [
                    { "Type": "ReleaseJobTarget" }
                  ]
                },
                {
                  "$Comment": "Job target exists and colonist is within harvesting range — switch to Working.",
                  "Sensor": { "Type": "JobTarget", "Range": 5.0 },
                  "Actions": [
                    { "Type": "State", "State": "Working" }
                  ]
                },
                {
                  "$Comment": "Shaft exhausted — wander gently near the workstation (where ECS delivery already walked the miner to). noWorkAvailable stays set so SeekNextMineBlock is never triggered again, and there is no ActionsBlocking wait that would freeze the colonist in place.",
                  "Sensor": { "Type": "NoWorkAvailable" },
                  "BodyMotion": {
                    "Type": "WanderInCircle",
                    "Radius": 3,
                    "MaxHeadingChange": 45,
                    "RelativeSpeed": 0.3
                  }
                },
                {
                  "$Comment": "Has tools — claim the next mine block or restore navigation to an existing target if lost (e.g. after restart).",
                  "Sensor": {
                    "Type": "And",
                    "Sensors": [
                      { "Type": "HasTool", "GatherType": "Rocks" },
                      { "Type": "HasTool", "GatherType": "Soils" }
                    ]
                  },
                  "Actions": [
                    { "Type": "SeekNextMineBlock" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "=== WORKING STATE === The miner is actively mining a claimed block. Break detection, quota, and seek-next are handled by the global instructions above.",
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Working" },
          "Instructions": [
            {
              "$Comment": "Self-transition keeps the Working state machinery cycling so the global instructions fire on every tick.",
              "Sensor": { "Type": "JobTarget", "Range": 5.0 },
              "Actions": [
                { "Type": "State", "State": "Working" }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "=== COLLECTING STATE === Picks up drops while ECS delivery pipeline runs, then returns to Idle.",
      "Instructions": [
        {
          "Sensor": { "Type": "State", "State": "Collecting" },
          "Instructions": [
            {
              "$Comment": "On first entry, signal the ECS delivery pipeline to start.",
              "Sensor": { "Type": "Any", "Once": true },
              "Actions": [
                { "Type": "SetEcsJobState", "State": "CollectingDrops" }
              ]
            },
            {
              "$Comment": "Wander the area while waiting for delivery so the colonist does not stand still.",
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "BodyMotion": {
                "Type": "WanderInCircle",
                "Radius": 5,
                "MaxHeadingChange": 60,
                "RelativeSpeed": 0.5
              }
            },
            {
              "$Comment": "Pick up nearby dropped items while waiting for delivery to complete.",
              "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
              "Actions": [
                { "Type": "PickUpItem", "Hoover": true }
              ]
            },
            {
              "$Comment": "ECS delivery pipeline finished (home, set Idle) — return to Idle role state.",
              "Sensor": { "Type": "EcsJobState", "State": "Idle" },
              "Actions": [
                { "Type": "State", "State": "Idle" }
              ]
            }
          ]
        }
      ]
    }
  ]
}

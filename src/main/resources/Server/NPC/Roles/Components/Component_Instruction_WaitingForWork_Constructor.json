{
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "HytaleColonies.Instruction.Colonist.WaitingForWork",
  "Content": {
    "$Comment": "WaitingForWork -- constructor: wander at workstation, check for all required tools (pickaxe, shovel, hatchet), wait for ECS to assign a build target.",
    "Sensor": { "Type": "Any" },
    "Instructions": [
      {
        "Continue": true,
        "Sensor": { "Type": "Any" },
        "BodyMotion": {
          "Type": "Sequence",
          "Looped": true,
          "Motions": [
            { "Type": "Timer", "Time": [4, 6], "Motion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 0.4 } },
            { "Type": "Timer", "Time": [1, 2], "Motion": { "Type": "Nothing" } }
          ]
        }
      },
      {
        "$Comment": "No pickaxe -- confused particle + wait.",
        "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["*_Pickaxe*"], "CountRange": [1, 999] }] } },
        "ActionsBlocking": true,
        "Actions": [
          { "Type": "LogDebug", "Message": "WaitingForWork: missing pickaxe -- showing confused particle.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
          { "Type": "Timeout", "Delay": [3, 3] }
        ]
      },
      {
        "$Comment": "No shovel -- confused particle + wait.",
        "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["*_Shovel*"], "CountRange": [1, 999] }] } },
        "ActionsBlocking": true,
        "Actions": [
          { "Type": "LogDebug", "Message": "WaitingForWork: missing shovel -- showing confused particle.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
          { "Type": "Timeout", "Delay": [3, 3] }
        ]
      },
      {
        "$Comment": "No hatchet -- confused particle + wait.",
        "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["*_Hatchet*"], "CountRange": [1, 999] }] } },
        "ActionsBlocking": true,
        "Actions": [
          { "Type": "LogDebug", "Message": "WaitingForWork: missing hatchet -- showing confused particle.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
          { "Type": "Timeout", "Delay": [3, 3] }
        ]
      },
      {
        "$Comment": "Target found -- travel to the claimed block.",
        "Sensor": { "Type": "JobTargetExists" },
        "Actions": [
          { "Type": "LogDebug", "Message": "WaitingForWork: target found -> TravelingToWorkSite.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "SetEcsJobState", "JobState": "TravelingToWorkSite" }
        ]
      }
    ]
  }
}

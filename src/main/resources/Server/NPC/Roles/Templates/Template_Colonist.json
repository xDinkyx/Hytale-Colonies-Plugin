{
  "$Comment": "Abstract base for all colonist roles. All state/sub-state sensors are defined here so ECS can reach them via role.getStateSupport().setState(). Components plug in leaf instruction bodies per sub-state.",
  "Type": "Abstract",
  "StartState": "Idle",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "server.npcRoles.Colonist.name",
      "Description": "Translation key for the NPC display name."
    },
    "Appearance": {
      "Value": "Mannequin",
      "Description": "Model to use for this colonist."
    },
    "MaxHealth": {
      "Value": 20,
      "Description": "Maximum health points."
    },
    "MaxSpeed": {
      "Value": 3,
      "Description": "Maximum walk speed."
    },
    "DebugCategory": {
      "Value": "COLONIST_JOB",
      "Description": "Debug log category used in inline state log messages and StateTransitions."
    },
    "HarvestingComponent": {
      "Value": "Component_Instruction_Harvesting_NoOp",
      "Description": "Seek-to-block and break-loop body for the Harvesting sub-state. Override for harvester jobs."
    },
    "WaitingForWorkComponent": {
      "Value": "Component_Instruction_WaitingForWork_Miner",
      "Description": "Tool-check and target-scan body for WaitingForWork. Override per job."
    },
    "TravelingToWorkSiteComponent": {
      "Value": "Component_Instruction_TravelingToWorkSite_Harvester",
      "Description": "Seek and arrival transition for TravelingToWorkSite. Override for jobs with a different arrival state."
    },
    "ClearingComponent": {
      "Value": "Component_Instruction_NoOp",
      "Description": "Seek-to-block and break-loop body for the Clearing sub-state (constructor). NoOp for other jobs."
    },
    "ConstructingComponent": {
      "Value": "Component_Instruction_NoOp",
      "Description": "Seek-to-block and place-block body for the Constructing sub-state (constructor). NoOp for other jobs."
    },
    "RetrievingBlocksComponent": {
      "Value": "Component_Instruction_NoOp",
      "Description": "Walk to container and retrieve materials for the RetrievingBlocks sub-state (constructor). NoOp for other jobs."
    },
    "DefaultIdleComponent": {
      "Value": "Component_Instruction_Idle_Default_Worker",
      "Description": "Behavior for the Default (entry) idle sub-state. Override for jobless wander."
    }
  },
  "Appearance": { "Compute": "Appearance" },
  "MaxHealth": { "Compute": "MaxHealth" },
  "NameTranslationKey": { "Compute": "NameTranslationKey" },
  "HotbarSize": 4,
  "InventorySize": 12,
  "MotionControllerList": [
    { "Type": "Walk", "MaxWalkSpeed": { "Compute": "MaxSpeed" } }
  ],
  "StateTransitions": [
    {
      "$Comment": "Put tool away when leaving Working main state.",
      "States": [{ "From": ["Working"], "To": [] }],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition Working ->.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
        { "Type": "Inventory", "Operation": "ClearHeldItem", "UseTarget": false }
      ]
    },
    {
      "$Comment": "Reset any stuck blocking instruction chain when entering Idle main state.",
      "States": [{ "From": [], "To": ["Idle"] }],
      "Actions": [
        { "Type": "LogDebug", "Message": "StateTransition -> Idle.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
        { "Type": "ResetInstructions" }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "Working -- gates all working-shift behavior.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Working", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "Harvesting #1 -- seek to block and break it (job-specific loop).",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "HarvestingComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        {
          "$Comment": "Harvesting #2 -- when block is air, notify ECS. Runs alongside #1 via Continue.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Harvesting", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Harvesting: block broken -- notifying ECS.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "NotifyBlockBroken" }
              ]
            }
          ]
        },
        {
          "$Comment": "Clearing #1 -- seek to block and break it (constructor loop).",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Clearing", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "ClearingComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        {
          "$Comment": "Clearing #2 -- when block is air, notify ECS. Runs alongside #1 via Continue.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Clearing", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "LogDebug", "Message": "Clearing: block broken -- notifying ECS.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "NotifyBlockBroken" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToWorkSite -- seek to claimed block and transition on arrival.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkSite", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "TravelingToWorkSiteComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        {
          "$Comment": "Constructing -- seek to block and place it.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".Constructing", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "ConstructingComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        {
          "$Comment": "RetrievingBlocks -- walk to container and pull materials.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".RetrievingBlocks", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "RetrievingBlocksComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        {
          "$Comment": "CollectingDrops -- wander and pick up drops. Timer elapsed -> DeliveringItems.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".CollectingDrops", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "BodyMotion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 60, "RelativeSpeed": 0.5 }
            },
            {
              "Continue": true,
              "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: picking up item.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "PickUpItem", "Hoover": true }
              ]
            },
            {
              "Sensor": { "Type": "CollectionTimerElapsed" },
              "Actions": [
                { "Type": "LogDebug", "Message": "CollectingDrops: timer elapsed -> DeliveringItems.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "SetEcsJobState", "JobState": "DeliveringItems" }
              ]
            }
          ]
        },
        {
          "$Comment": "DeliveringItems -- find container, seek to it, deposit and head home.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".DeliveringItems", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: scanning for delivery container.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "FindDeliveryContainer" }
              ]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "JobTarget", "Range": 3.0 },
              "Actions": [
                { "Type": "LogDebug", "Message": "DeliveringItems: depositing and heading home.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "DepositItems" },
                { "Type": "SetEcsJobState", "JobState": "TravelingToHome" }
              ]
            }
          ]
        },
        {
          "$Comment": "WaitingForWork -- job-specific tool checks and target scan.",
          "Sensor": { "Type": "State", "State": ".WaitingForWork", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "WaitingForWorkComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.WaitingForWork" ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    },
    {
      "$Comment": "Idle -- gates all off-shift behavior.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Idle", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "TravelingToWorkstation -- seek to workstation, arrive -> WaitingForWork.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToWorkstation", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [{ "Type": "NavigateToWorkstation" }]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToWorkstation: arrived -> WaitingForWork.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "SetEcsJobState", "JobState": "WaitingForWork" }
              ]
            }
          ]
        },
        {
          "$Comment": "TravelingToHome -- return to workstation area after delivery.",
          "Continue": true,
          "Sensor": { "Type": "State", "State": ".TravelingToHome", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [{ "Type": "NavigateToWorkstation" }]
            },
            {
              "Continue": true,
              "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
              "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
            },
            {
              "Sensor": { "Type": "AtWorkstation" },
              "Actions": [
                { "Type": "LogDebug", "Message": "TravelingToHome: arrived -> Idle.", "Category": { "Compute": "DebugCategory" }, "Level": "FINE" },
                { "Type": "SetEcsJobState", "JobState": "Idle" }
              ]
            }
          ]
        },
        {
          "$Comment": "Default -- entry state, navigate to workstation and begin travel.",
          "Sensor": { "Type": "State", "State": ".Default", "IgnoreMissingSetState": true },
          "Instructions": [
            {
              "Reference": { "Compute": "DefaultIdleComponent" },
              "Interfaces": [ "HytaleColonies.Instruction.Colonist.StateBody" ]
            }
          ]
        },
        { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
      ]
    },
    { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Continue": true,
        "Sensor": { "Type": "Any" },
        "Actions": [
          { "Type": "SetInteractable", "Interactable": true, "Hint": "server.interactionHints.generic" }
        ]
      },
      {
        "Sensor": { "Type": "HasInteracted" },
        "Instructions": [
          {
            "Sensor": { "Type": "Any" },
            "Actions": [
              { "Type": "OpenColonistInspectPage" }
            ]
          }
        ]
      }
    ]
  }
}
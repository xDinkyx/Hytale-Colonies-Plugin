{
  "$Comment": "Constructing body for the Constructor -- seeks to target block and places it.",
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "HytaleColonies.Instruction.Colonist.StateBody",
  "Content": {
    "Sensor": { "Type": "Any" },
    "Instructions": [
      {
        "Continue": true,
        "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
        "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
      },
      {
        "Sensor": { "Type": "JobTarget", "Range": 2.5 },
        "ActionsBlocking": true,
        "Actions": [
          { "Type": "LogDebug", "Message": "Constructing: placing block.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "PlaceConstructionBlock" },
          { "Type": "Timeout", "Delay": [0.6, 0.8] }
        ]
      }
    ]
  }
}

{
  "$Comment": "Clearing loop body for the Constructor -- seeks to the target block and breaks it.",
  "Type": "Component",
  "Class": "Instruction",
  "Interface": "HytaleColonies.Instruction.Colonist.StateBody",
  "Content": {
    "Sensor": { "Type": "Any" },
    "Instructions": [
      {
        "Continue": true,
        "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.5 },
        "BodyMotion": { "Type": "Seek", "StopDistance": 1.0, "SlowDownDistance": 2.0, "RelativeSpeed": 0.8 }
      },
      {
        "Sensor": { "Type": "JobTarget", "Range": 2.5 },
        "ActionsBlocking": true,
        "Actions": [
          { "Type": "LogDebug", "Message": "Clearing: breaking block.", "Category": "CONSTRUCTOR_JOB", "Level": "FINE" },
          { "Type": "EquipBestTool" },
          { "Type": "HarvestBlock", "DamageScale": 0.1 },
          { "Type": "Timeout", "Delay": [0.5, 0.5] }
        ]
      }
    ]
  }
}

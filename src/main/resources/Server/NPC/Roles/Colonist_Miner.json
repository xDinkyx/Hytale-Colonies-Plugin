{
  "Type": "Generic",
  "Appearance": "Mannequin",
  "MaxHealth": 20,
  "NameTranslationKey": "server.npcRoles.Colonist_Miner.name",
  "MotionControllerList": [
    { "Type": "Walk", "MaxWalkSpeed": 4 }
  ],
  "Instructions": [
    {
      "$Comment": "Global navigation — always running. ECS writes NavTarget slot via PathFindingSystem; JSON drives the body toward it.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.5 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 1.5, "SlowDownDistance": 3, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "Working — mine the target block while in range. ActionsBlocking sequences equip→swing→cooldown each cycle.",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "EcsJobState", "JobState": "Working" },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTarget", "Range": 5.0 },
              "ActionsBlocking": true,
              "Actions": [
                { "Type": "EquipBestTool" },
                { "Type": "HarvestBlock", "DamageScale": 0.1 },
                { "Type": "Timeout", "Delay": [0.5, 0.5] }
              ]
            }
          ]
        }
      ]
    },
    {
      "$Comment": "Working — when job-target block is air, notify ECS. ECS decides the next state (quota check, next block, or collect).",
      "Continue": true,
      "Instructions": [
        {
          "Sensor": { "Type": "EcsJobState", "JobState": "Working" },
          "Instructions": [
            {
              "Sensor": { "Type": "JobTargetBroken" },
              "Actions": [
                { "Type": "NotifyBlockBroken" }
              ]
            }
          ]
        }
      ]
    },
    {
      "Sensor": { "Type": "Any" },
      "BodyMotion": { "Type": "Nothing" }
    }
  ]
}
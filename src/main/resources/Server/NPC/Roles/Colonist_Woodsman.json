{
  "$Comment": "Woodsman colonist role -- handles finding, navigating to, and harvesting trees.",
  "Type": "Generic",
  "Appearance": "Mannequin",
  "NameTranslationKey": "server.npcRoles.Colonist_Woodsman.name",
  "MaxHealth": 20,
  "InventorySize": 12,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 3
    }
  ],
  "StateTransitions": [
    {
      "$Comment": "Equip best woodcutting tool when entering Working.",
      "States": [
        { "From": [], "To": ["Working"] }
      ],
      "Actions": [
        { "Type": "EquipBestTool", "GatherType": "Woods" }
      ]
    },
    {
      "$Comment": "Put tool away when leaving Working (traveling, collecting, delivering, idling).",
      "States": [
        { "From": ["Working"], "To": [] }
      ],
      "Actions": [
        { "Type": "Inventory", "Operation": "ClearHeldItem", "UseTarget": false }
      ]
    },
    {
      "$Comment": "Reset any stuck blocking instruction chain when returning to Idling.",
      "States": [
        { "From": [], "To": ["Idling"] }
      ],
      "Actions": [
        { "Type": "ResetInstructions" }
      ]
    }
  ],
  "Instructions": [
    {
      "$Comment": "TravelingToJob -- seek to claimed tree. ECS writes NavTarget via PathFindingSystem.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "TravelingToJob", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "Working -- approach tree and chop. Seek handles final approach so the NPC gets close enough; chop fires once within range.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Working", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0, "MinRange": 1.5 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 1.0, "SlowDownDistance": 2.0, "RelativeSpeed": 0.8 }
        },
        {
          "Sensor": { "Type": "JobTarget", "Range": 2.5 },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "EquipBestTool" },
            { "Type": "HarvestBlock", "DamageScale": 0.1 },
            { "Type": "Timeout", "Delay": [0.5, 0.5] }
          ]
        }
      ]
    },
    {
      "$Comment": "Working -- when job-target block is air, notify ECS. ECS decides the next state (next trunk, collect, etc).",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Working", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Sensor": { "Type": "JobTargetBroken" },
          "Actions": [
            { "Type": "NotifyBlockBroken" }
          ]
        }
      ]
    },
    {
      "$Comment": "CollectingDrops -- wander area and pick up drops while ECS delivery pipeline runs.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "CollectingDrops", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": { "Type": "Any" },
          "BodyMotion": { "Type": "WanderInCircle", "Radius": 5, "MaxHeadingChange": 60, "RelativeSpeed": 0.5 }
        },
        {
          "Sensor": { "Type": "DroppedItem", "Range": 5.0 },
          "Actions": [
            { "Type": "PickUpItem", "Hoover": true }
          ]
        }
      ]
    },
    {
      "$Comment": "DeliveringItems -- seek to delivery container. ECS writes NavTarget.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "DeliveringItems", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "TravelingHome -- seek back to workstation. ECS writes NavTarget.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "TravelingHome", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 200.0, "MinRange": 1.0 },
          "BodyMotion": { "Type": "Seek", "StopDistance": 0.5, "SlowDownDistance": 4, "RelativeSpeed": 1.0 }
        }
      ]
    },
    {
      "$Comment": "Idling -- wander near workstation; confused particle when axe is missing.",
      "Continue": true,
      "Sensor": { "Type": "State", "State": "Idling", "IgnoreMissingSetState": true },
      "Instructions": [
        {
          "$Comment": "Wander near workstation (WanderInCircle uses leash point set by ECS). Continue: true so tool-check block below also runs.",
          "Continue": true,
          "Sensor": { "Type": "ReadPosition", "Slot": "NavTarget", "Range": 5.0 },
          "BodyMotion": {
            "Type": "Sequence",
            "Looped": true,
            "Motions": [
              { "Type": "Timer", "Time": [4, 6], "Motion": { "Type": "WanderInCircle", "Radius": 3, "MaxHeadingChange": 45, "RelativeSpeed": 0.35 } },
              { "Type": "Timer", "Time": [1, 2], "Motion": { "Type": "Nothing" } }
            ]
          }
        },
        {
          "$Comment": "No hatchet -- confused particle + wait.",
          "Sensor": { "Type": "Not", "Sensor": { "Type": "Self", "Filters": [{ "Type": "Inventory", "Items": ["Tool_Hatchet_*"], "CountRange": [1, 999] }] } },
          "ActionsBlocking": true,
          "Actions": [
            { "Type": "SpawnParticles", "ParticleSystem": "Question_Subtle", "Offset": [0, 2.1, 0] },
            { "Type": "Timeout", "Delay": [3, 3] }
          ]
        }
      ]
    },
    {
      "Sensor": { "Type": "Any" },
      "BodyMotion": { "Type": "Nothing" }
    }
  ]
}
